# AgroCLI Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# AI PROVIDERS (Optional - Choose one or configure multiple)
# ═══════════════════════════════════════════════════════════════════

# Google Gemini API (Recommended - Fast & Free tier available)
# Get your key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API (Advanced reasoning)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (ChatGPT-4/5)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ═══════════════════════════════════════════════════════════════════
# WEATHER API (Optional - for weather-aware watering)
# ═══════════════════════════════════════════════════════════════════

OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_CITY=Surabaya

# ═══════════════════════════════════════════════════════════════════
# NOTIFICATIONS (Optional)
# ═══════════════════════════════════════════════════════════════════

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=agrocli@yourdomain.com
NOTIFICATION_EMAIL=recipient@example.com

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Custom Webhook (for IFTTT, Zapier, etc.)
CUSTOM_WEBHOOK_URL=https://your-webhook-url.com/endpoint

# ═══════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Database
DATABASE_PATH=data/garden.db

# Web Server
HOST=0.0.0.0
PORT=8001

# Daemon
DAEMON_CYCLE_INTERVAL=5  # seconds between sensor checks
DAEMON_DB_LOG_INTERVAL=60  # seconds between database writes
ENABLE_NOTIFICATIONS=true  # enable/disable all notifications

# ═══════════════════════════════════════════════════════════════════
# HARDWARE CONFIGURATION (for real sensors)
# ═══════════════════════════════════════════════════════════════════

SENSOR_TYPE=mock  # mock or real
I2C_ADDRESS=0x48  # for real I2C sensors

# Pump Configuration
PUMP_GPIO_PIN=17  # GPIO pin for pump relay (Raspberry Pi)
PUMP_DEFAULT_DURATION=3  # seconds

# Failsafe
PUMP_MAX_CONSECUTIVE_TRIGGERS=5  # lock pump after this many triggers

# ═══════════════════════════════════════════════════════════════════
# ANALYTICS & LOGGING
# ═══════════════════════════════════════════════════════════════════

ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

LOG_LEVEL=INFO
LOG_FILE=logs/security.log
