# AgroCLI Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit the .env file to version control.

# Security
SECRET_KEY=generate_a_secure_random_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Weather API
# Get your key at https://openweathermap.org/
WEATHER_API_KEY=your_weather_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8001
ENABLE_HTTPS=false

# SSL Certificates (if ENABLE_HTTPS=true)
SSL_KEYFILE=key.pem
SSL_CERTFILE=cert.pem

# Rate Limiting
RATE_LIMIT_PUMP=5/minute
RATE_LIMIT_API=100/minute

# Database
DB_PATH=data/garden.db
ENABLE_DB_ENCRYPTION=false
DB_ENCRYPTION_KEY=your-db-encryption-key

# Logging
LOG_LEVEL=INFO
SECURITY_LOG_FILE=logs/security.log

# Telegram Notifications
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AI Agent (Google Gemini)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
